{
  "id": "enterprise-light",
  "name": "企业浅色咨询",
  "version": "1.0.0",
  "colors": {
    "background": "#FFFFFF",
    "surface": "#FAFAFA",
    "surfaceAlt": "#F5F5F5",
    "primary": "#1A1A1A",
    "secondary": "#404040",
    "tertiary": "#737373",
    "accent": "#0F172A",
    "accentSoft": "#E2E8F0",
    "accentHover": "#1E293B",
    "positive": "#15803D",
    "positiveSoft": "#DCFCE7",
    "warning": "#B45309",
    "warningSoft": "#FEF3C7",
    "danger": "#B91C1C",
    "dangerSoft": "#FEE2E2",
    "line": "#E5E5E5",
    "lineStrong": "#D4D4D4",
    "textPrimary": "#171717",
    "textSecondary": "#525252",
    "textTertiary": "#A3A3A3",
    "textOnAccent": "#FFFFFF",
    "overlay": "rgba(0, 0, 0, 0.5)"
  },
  "fonts": {
    "heading": {
      "family": "'Helvetica Neue', Helvetica, Arial, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif",
      "fallback": "sans-serif"
    },
    "body": {
      "family": "'Helvetica Neue', Helvetica, Arial, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif",
      "fallback": "sans-serif"
    },
    "mono": {
      "family": "'SF Mono', 'Fira Code', Menlo, Consolas, monospace",
      "fallback": "monospace"
    }
  },
  "typography": {
    "coverTitle": {
      "size": 60,
      "weight": 700,
      "lineHeight": 1.12
    },
    "coverSubtitle": {
      "size": 26,
      "weight": 400,
      "lineHeight": 1.5
    },
    "sectionTitle": {
      "size": 52,
      "weight": 700,
      "lineHeight": 1.18
    },
    "slideTitle": {
      "size": 36,
      "weight": 600,
      "lineHeight": 1.22
    },
    "slideSubtitle": {
      "size": 22,
      "weight": 400,
      "lineHeight": 1.5
    },
    "bodyLarge": {
      "size": 22,
      "weight": 400,
      "lineHeight": 1.6
    },
    "body": {
      "size": 19,
      "weight": 400,
      "lineHeight": 1.65
    },
    "bodySmall": {
      "size": 17,
      "weight": 400,
      "lineHeight": 1.55
    },
    "caption": {
      "size": 15,
      "weight": 400,
      "lineHeight": 1.45
    },
    "metricValue": {
      "size": 52,
      "weight": 700,
      "lineHeight": 1.08
    },
    "metricLabel": {
      "size": 16,
      "weight": 500,
      "lineHeight": 1.4
    }
  },
  "spacing": {
    "pageX": 96,
    "pageY": 72,
    "sectionGap": 52,
    "elementGap": 28,
    "cardPadding": 36,
    "cardGap": 24,
    "listIndent": 30,
    "listGap": 14
  },
  "shape": {
    "borderRadius": 4,
    "borderRadiusSmall": 2,
    "borderRadiusLarge": 8,
    "borderWidth": 1,
    "borderWidthStrong": 2
  },
  "shadow": {
    "card": "0 1px 2px rgba(0,0,0,0.04)",
    "elevated": "0 2px 8px rgba(0,0,0,0.08)",
    "float": "0 8px 24px rgba(0,0,0,0.1)"
  },
  "charts": {
    "palette": [
      "#0F172A",
      "#334155",
      "#475569",
      "#64748B",
      "#0369A1",
      "#0F766E",
      "#B45309",
      "#525252"
    ],
    "gridColor": "#F0F0F0",
    "axisColor": "#D4D4D4"
  },
  "footer": {
    "showPageNumber": true,
    "showBrand": true,
    "brandText": "[Your Brand]",
    "textColor": "#A3A3A3",
    "fontSize": 13
  },
  "logo": {
    "position": "top-left",
    "height": 28,
    "marginX": 96,
    "marginY": 52
  }
}
