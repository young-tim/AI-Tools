# 复制到业务项目根 .env

DIFY_CONSOLE_URL=https://your-dify-host.com
DIFY_BASE_URL=https://your-dify-host.com/v1
DIFY_EMAIL=
DIFY_PASSWORD=

# SSO / 手动 Cookie（无 .dify/session.json 时）
DIFY_CONSOLE_TOKEN=
DIFY_CSRF_TOKEN=
DIFY_REFRESH_TOKEN=

# DIFY_ENV_FILE=/path/to/.env
# DIFY_SESSION_FILE=/path/to/.dify/session.json
