        {
          "name": "title",
          "type": "string",
          "required": false,
          "default": null,
          "description": "图表标题"
        },
        {
          "name": "categories",
          "type": "array",
          "required": true,
          "default": null,
          "description": "X轴标签数组（通常为时间点）"
        },
        {
          "name": "series",
          "type": "array",
          "required": true,
          "default": null,
