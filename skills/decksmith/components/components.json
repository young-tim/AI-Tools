            ["准确率", "82%", "95%", "+13pp"],
            ["日均处理量", "5000条", "50000条", "10x"]
          ],
          "summary": null,
          "headerBg": true,
          "zebra": true,
          "columnWidths": [2, 1, 1, 1]
        },
        "position": { "x": 96, "y": 240, "width": 1728, "height": 400 },
        "style": { "variant": "default", "color": "default", "align": "left" }
      }
    },
    {
      "id": "bar-chart",
