{
  "version": "1.0",
  "components": [
    {
      "id": "title",
      "name": "页面标题",
      "category": "layout",
      "description": "页面核心结论标题，必须使用结论式表达，禁止仅描述主题",
      "pptxStrategy": "native",
      "props": [
        {
          "name": "text",
          "type": "string",
          "required": true,
          "default": null,
          "description": "标题文本内容，应为结论式陈述"
        },
        {
          "name": "level",
          "type": "enum",
          "required": false,
          "default": "h1",
          "description": "标题层级：cover(封面)/section(章节)/h1(页面)/h2(区域)",
          "enum": ["cover", "section", "h1", "h2"]
        },
        {
          "name": "accent",
          "type": "boolean",
          "required": false,
          "default": false,
          "description": "是否显示标题左侧强调色条"
        }
      ],
      "example": {
        "id": "title-1",
        "type": "title",
        "props": {
          "text": "当前审核流程的主要瓶颈是人工判断无法规模化",
          "level": "h1",
          "accent": true
        },
        "position": { "x": 96, "y": 72, "width": 1728, "height": 80 },
        "style": { "variant": "default", "color": "primary", "align": "left" }
      }
    },
    {
      "id": "subtitle",
      "name": "页面副标题",
      "category": "layout",
      "description": "标题下方的补充说明文字，提供上下文或解释",
      "pptxStrategy": "native",
      "props": [
        {
          "name": "text",
          "type": "string",
          "required": true,
          "default": null,
          "description": "副标题文本内容"
        },
        {
          "name": "size",
          "type": "enum",
          "required": false,
          "default": "medium",
          "description": "字号大小：small/medium/large",
          "enum": ["small", "medium", "large"]
        }
      ],
      "example": {
        "id": "subtitle-1",
        "type": "subtitle",
        "props": {
          "text": "从人工经验驱动，转向结构化、可复用的业务能力",
          "size": "medium"
        },
        "position": { "x": 96, "y": 160, "width": 1728, "height": 48 },
        "style": { "variant": "default", "color": "secondary", "align": "left" }
      }
    },
    {
      "id": "body-text",
      "name": "正文段落",
      "category": "content",
      "description": "正文段落文本，支持多段落展示",
      "pptxStrategy": "native",
      "props": [
        {
          "name": "paragraphs",
          "type": "array",
          "required": true,
          "default": null,
          "description": "段落文本数组，每个元素为一个段落"
        },
        {
          "name": "lineHeight",
          "type": "number",
          "required": false,
          "default": 1.6,
          "description": "行高倍数"
        },
        {
          "name": "fontSize",
          "type": "enum",
          "required": false,
          "default": "medium",
          "description": "字号规格：small(20px)/medium(24px)/large(32px)",
          "enum": ["small", "medium", "large"]
        }
      ],
      "example": {
        "id": "body-1",
        "type": "body-text",
        "props": {
          "paragraphs": [
            "平台通过自动化流程将审核效率提升3倍以上，同时保持95%以上的准确率。",
            "系统支持自定义规则配置，可快速适配不同业务场景的审核需求。"
          ],
          "lineHeight": 1.6,
          "fontSize": "medium"
        },
        "position": { "x": 96, "y": 240, "width": 800, "height": 200 },
        "style": { "variant": "default", "color": "default", "align": "left" }
      }
    },
    {
      "id": "bullet-list",
      "name": "要点列表",
      "category": "content",
      "description": "项目符号要点列表，用于展示关键论点、措施或发现",
      "pptxStrategy": "native",
      "props": [
        {
          "name": "items",
          "type": "array",
          "required": true,
          "default": null,
          "description": "列表项数组，每项为字符串或{text, highlight?, children?}结构"
        },
        {
          "name": "bulletStyle",
          "type": "enum",
          "required": false,
          "default": "dot",
          "description": "列表符号样式：dot/check/arrow/number/none",
          "enum": ["dot", "check", "arrow", "number", "none"]
        },
        {
          "name": "columns",
          "type": "number",
          "required": false,
          "default": 1,
          "description": "分列数量，支持1-3列"
        }
      ],
      "example": {
        "id": "bullets-1",
        "type": "bullet-list",
        "props": {
          "items": [
            { "text": "自动化审核覆盖率达85%，人工仅需处理高风险案例" },
            { "text": "平均审核时长从4小时缩短至15分钟", "highlight": true },
            { "text": "支持多模态内容审核：文本、图片、视频" }
          ],
          "bulletStyle": "check",
          "columns": 1
        },
        "position": { "x": 96, "y": 240, "width": 800, "height": 300 },
        "style": { "variant": "default", "color": "default", "align": "left" }
      }
    },
    {
      "id": "metric-card",
      "name": "指标卡片",
      "category": "content",
      "description": "核心数据指标展示卡片，突出关键数字与趋势",
      "pptxStrategy": "native",
      "props": [
        {
          "name": "value",
          "type": "string",
          "required": true,
          "default": null,
          "description": "指标数值，如 '85%'、'1.2亿'、'3x'"
        },
        {
          "name": "label",
          "type": "string",
          "required": true,
          "default": null,
          "description": "指标名称/标签"
        },
        {
          "name": "trend",
          "type": "enum",
          "required": false,
          "default": null,
          "description": "趋势方向：up(上升)/down(下降)/flat(持平)",
          "enum": ["up", "down", "flat"]
        },
        {
          "name": "trendValue",
          "type": "string",
          "required": false,
          "default": null,
          "description": "趋势变化值，如 '+23%'、'-5%'"
        },
        {
          "name": "description",
          "type": "string",
          "required": false,
          "default": null,
          "description": "指标补充说明文字"
        },
        {
          "name": "icon",
          "type": "string",
          "required": false,
          "default": null,
          "description": "卡片图标asset ID"
        }
      ],
      "example": {
        "id": "metric-1",
        "type": "metric-card",
        "props": {
          "value": "85%",
          "label": "自动化覆盖率",
          "trend": "up",
          "trendValue": "+23%",
          "description": "较上季度提升23个百分点"
        },
        "position": { "x": 96, "y": 240, "width": 380, "height": 200 },
        "style": { "variant": "elevated", "color": "primary", "align": "center" }
      }
    },
    {
      "id": "image",
      "name": "图片",
      "category": "visual",
      "description": "图片、产品截图、照片等视觉素材展示",
      "pptxStrategy": "native",
      "props": [
        {
          "name": "src",
          "type": "string",
          "required": true,
          "default": null,
          "description": "图片资源asset ID或本地路径"
        },
        {
          "name": "alt",
          "type": "string",
          "required": false,
          "default": "",
          "description": "图片替代文本（无障碍）"
        },
        {
          "name": "fit",
          "type": "enum",
          "required": false,
          "default": "contain",
          "description": "图片适配模式：contain(等比适应)/cover(等比填充)/stretch(拉伸)",
          "enum": ["contain", "cover", "stretch"]
        },
        {
          "name": "caption",
          "type": "string",
          "required": false,
          "default": null,
          "description": "图片说明文字"
        },
        {
          "name": "borderRadius",
          "type": "number",
          "required": false,
          "default": 0,
          "description": "圆角半径(px)"
        },
        {
          "name": "shadow",
          "type": "boolean",
          "required": false,
          "default": false,
          "description": "是否添加投影效果"
        }
      ],
      "example": {
        "id": "img-1",
        "type": "image",
        "props": {
          "src": "assets/images/product-dashboard.png",
          "alt": "产品控制台界面截图",
          "fit": "cover",
          "caption": "图1：智能审核控制台全景",
          "borderRadius": 12,
          "shadow": true
        },
        "position": { "x": 960, "y": 240, "width": 864, "height": 540 },
        "style": { "variant": "default", "color": "default", "align": "center" }
      }
    },
    {
      "id": "icon",
      "name": "图标",
      "category": "visual",
      "description": "矢量图标，用于辅助视觉引导和信息层级",
      "pptxStrategy": "svg",
      "props": [
        {
          "name": "name",
          "type": "string",
          "required": true,
          "default": null,
          "description": "图标名称/ID，对应图标库"
        },
        {
          "name": "size",
          "type": "enum",
          "required": false,
          "default": "medium",
          "description": "图标尺寸：small(24px)/medium(32px)/large(48px)/xlarge(64px)",
          "enum": ["small", "medium", "large", "xlarge"]
        },
        {
          "name": "src",
          "type": "string",
          "required": false,
          "default": null,
          "description": "自定义图标SVG文件asset ID（优先于name）"
        }
      ],
      "example": {
        "id": "icon-1",
        "type": "icon",
        "props": {
          "name": "check-circle",
          "size": "large"
        },
        "position": { "x": 96, "y": 240, "width": 48, "height": 48 },
        "style": { "variant": "default", "color": "success", "align": "center" }
      }
    },
    {
      "id": "comparison-panel",
      "name": "对比面板",
      "category": "content",
      "description": "左右/上下对比卡片组，用于方案对比、前后对比、优劣势分析",
      "pptxStrategy": "native",
      "props": [
        {
          "name": "panels",
          "type": "array",
          "required": true,
          "default": null,
          "description": "对比面板数组，每项包含{title, items, badge?, highlight?}"
        },
        {
          "name": "layout",
          "type": "enum",
          "required": false,
          "default": "horizontal",
          "description": "对比方向：horizontal(左右)/vertical(上下)",
          "enum": ["horizontal", "vertical"]
        },
        {
          "name": "showDivider",
          "type": "boolean",
          "required": false,
          "default": true,
          "description": "是否显示中间分隔线/VS标记"
        }
      ],
      "example": {
        "id": "compare-1",
        "type": "comparison-panel",
        "props": {
          "panels": [
            {
              "title": "传统流程",
              "badge": "Before",
              "items": ["人工逐条审核", "平均耗时4小时", "标准不统一", "难以规模化"],
              "highlight": false
            },
            {
              "title": "AI协同流程",
              "badge": "After",
              "items": ["机器预审+人工复核", "平均耗时15分钟", "标准统一可追溯", "弹性扩展能力"],
              "highlight": true
            }
          ],
          "layout": "horizontal",
          "showDivider": true
        },
        "position": { "x": 96, "y": 240, "width": 1728, "height": 500 },
        "style": { "variant": "card", "color": "default", "align": "left" }
      }
    },
    {
      "id": "process-node",
      "name": "流程节点",
      "category": "content",
      "description": "流程图节点，可串联形成业务流程或处理步骤",
      "pptxStrategy": "native",
      "props": [
        {
          "name": "steps",
          "type": "array",
          "required": true,
          "default": null,
          "description": "流程步骤数组，每项包含{title, description?, status?}"
        },
        {
          "name": "direction",
          "type": "enum",
          "required": false,
          "default": "horizontal",
          "description": "流程方向：horizontal(水平)/vertical(垂直)",
          "enum": ["horizontal", "vertical"]
        },
        {
          "name": "showConnectors",
          "type": "boolean",
          "required": false,
          "default": true,
          "description": "是否显示节点间连接线和箭头"
        },
        {
          "name": "stepStyle",
          "type": "enum",
          "required": false,
          "default": "numbered",
          "description": "节点样式：numbered(数字)/circle(圆点)/icon(图标)/card(卡片)",
          "enum": ["numbered", "circle", "icon", "card"]
        }
      ],
      "example": {
        "id": "process-1",
        "type": "process-node",
        "props": {
          "steps": [
            { "title": "素材接入", "description": "多渠道内容统一接入", "status": "completed" },
            { "title": "智能预审", "description": "AI引擎自动识别分类", "status": "completed" },
            { "title": "风险分级", "description": "按风险等级自动路由", "status": "current" },
            { "title": "人工复核", "description": "高风险内容人工审定", "status": "pending" },
            { "title": "结果输出", "description": "审核结果同步业务系统", "status": "pending" }
          ],
          "direction": "horizontal",
          "showConnectors": true,
          "stepStyle": "numbered"
        },
        "position": { "x": 96, "y": 300, "width": 1728, "height": 200 },
        "style": { "variant": "default", "color": "primary", "align": "center" }
      }
    },
    {
      "id": "timeline-node",
      "name": "时间轴节点",
      "category": "content",
      "description": "时间轴节点，用于展示里程碑、历史事件或规划阶段",
      "pptxStrategy": "native",
      "props": [
        {
          "name": "events",
          "type": "array",
          "required": true,
          "default": null,
          "description": "时间事件数组，每项包含{date, title, description?, status?}"
        },
        {
          "name": "alignment",
          "type": "enum",
          "required": false,
          "default": "center",
          "description": "时间轴对齐：left(左侧)/center(居中交替)/right(右侧)",
          "enum": ["left", "center", "right"]
        },
        {
          "name": "showAxis",
          "type": "boolean",
          "required": false,
          "default": true,
          "description": "是否显示时间轴线"
        }
      ],
      "example": {
        "id": "timeline-1",
        "type": "timeline-node",
        "props": {
          "events": [
            { "date": "Q1 2026", "title": "项目启动", "description": "完成需求调研与方案设计", "status": "completed" },
            { "date": "Q2 2026", "title": "核心开发", "description": "AI引擎与审核平台开发", "status": "current" },
            { "date": "Q3 2026", "title": "试点上线", "description": "选取业务线灰度试运行", "status": "pending" },
            { "date": "Q4 2026", "title": "全面推广", "description": "全业务线覆盖运营", "status": "pending" }
          ],
          "alignment": "center",
          "showAxis": true
        },
        "position": { "x": 96, "y": 240, "width": 1728, "height": 500 },
        "style": { "variant": "default", "color": "primary", "align": "left" }
      }
    },
    {
      "id": "table",
      "name": "数据表格",
      "category": "content",
      "description": "结构化数据表格展示，支持表头、数据行、汇总行",
      "pptxStrategy": "native",
      "props": [
        {
          "name": "headers",
          "type": "array",
          "required": true,
          "default": null,
          "description": "表头列名数组"
        },
        {
          "name": "rows",
          "type": "array",
          "required": true,
          "default": null,
          "description": "数据行二维数组，每行与headers对应"
        },
        {
          "name": "summary",
          "type": "array",
          "required": false,
          "default": null,
          "description": "汇总行数据（可选）"
        },
        {
          "name": "headerBg",
          "type": "boolean",
          "required": false,
          "default": true,
          "description": "表头是否使用背景色"
        },
        {
          "name": "zebra",
          "type": "boolean",
          "required": false,
          "default": true,
          "description": "是否使用斑马纹交替行背景"
        },
        {
          "name": "columnWidths",
          "type": "array",
          "required": false,
          "default": null,
          "description": "各列宽度比例数组，如[1,2,1,1]"
        }
      ],
      "example": {
        "id": "table-1",
